OPENAI_API_KEY=sk-your-key-here

# SQL Server (server-side only — used in config.yaml as ${MSSQL_DATABASE_URL})
# Example (ODBC Driver 18):
# MSSQL_DATABASE_URL=mssql+pyodbc://USER:PASSWORD@your-server.database.windows.net:1433/YourDb?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# Opaque token for CLI (from: nlp-sql auth --client-id ... --client-secret ...)
# NLP_SQL_ACCESS_TOKEN=

# Optional: issue custom scoped tokens via POST /v1/auth/token/admin
# NLP_SQL_ADMIN_SECRET=your-admin-secret

# NLP_SQL_CONFIG=/absolute/path/to/config.yaml
